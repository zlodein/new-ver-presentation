# Скопируйте в .env.production перед сборкой для продакшена.
# Оставьте VITE_API_URL пустым — фронт будет ходить на /api (ваш домен через Nginx).
# Не указывайте localhost — иначе на сайте запросы пойдут на компьютер пользователя.
VITE_API_URL=

# OneSignal Web Push (из настроек вашего OneSignal-приложения).
VITE_ONESIGNAL_APP_ID=
VITE_ONESIGNAL_SAFARI_WEB_ID=
